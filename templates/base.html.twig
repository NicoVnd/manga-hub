<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Manga Hub{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;600;700&family=Bangers&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Zen Kaku Gothic New', 'ui-sans-serif', 'system-ui', 'Segoe UI', 'Roboto', 'Arial', 'Noto Sans JP', 'sans-serif'],
              display: ['Bangers', 'Zen Kaku Gothic New', 'sans-serif']
            },
            colors: {
              night: { 900: '#0b1220', 800: '#121a2b' },
              sakura: { 400: '#ff8bb7', 500: '#ff6da3', 600: '#e2548a' },
              neon: { 400: '#22d3ee', 500: '#06b6d4' }
            },
            boxShadow: {
              glow: '0 0 24px rgba(6, 182, 212, 0.35)'
            },
            backgroundImage: {
              'anime-grid': 'radial-gradient(ellipse at top left, rgba(34,211,238,0.15), transparent 40%), radial-gradient(ellipse at bottom right, rgba(255,109,163,0.12), transparent 40%)'
            }
          }
        }
      }
    </script>
  </head>
  <body class="min-h-screen bg-night-900 bg-anime-grid text-slate-100 font-sans">
    <header class="border-b border-slate-800/60 bg-night-800/40 backdrop-blur">
      <div class="max-w-6xl mx-auto p-4 flex justify-between items-center">
        <a href="{{ path('app_home') }}" class="text-2xl font-display tracking-wide text-transparent bg-clip-text bg-gradient-to-r from-sakura-500 to-neon-500">Manga Hub</a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="{{ path('anime_index') }}" class="text-slate-300 hover:text-white hover:underline decoration-neon-500 underline-offset-4">Animes</a>
          {% if app.user %}
            <span class="hidden md:inline-flex items-center gap-2 text-slate-400">
              <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-slate-800 text-slate-200 text-xs">
                {{ app.user.userIdentifier|slice(0,1)|upper }}
              </span>
              Bonjour, {{ app.user.userIdentifier }}
            </span>
            <a href="{{ path('app_logout') }}" class="inline-flex items-center px-3 py-1 rounded-md border border-slate-700 bg-slate-800/60 text-slate-200 hover:bg-slate-700">Déconnexion</a>
          {% else %}
            <a href="{{ path('app_login') }}" class="text-slate-300 hover:text-white">Connexion</a>
            <a href="{{ path('app_register') }}" class="inline-flex items-center px-3 py-1 rounded-md bg-gradient-to-r from-sakura-500 to-neon-500 text-night-900 font-semibold hover:opacity-90">Inscription</a>
          {% endif %}
        </nav>
      </div>
    </header>
    <main class="max-w-6xl mx-auto p-4">{% block body %}{% endblock %}</main>
  </body>
</html>