{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<section class="max-w-md mx-auto">
  <div class="rounded-xl border border-slate-800 bg-night-800/50 p-6 backdrop-blur">
    <h1 class="text-2xl font-display font-bold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-sakura-500 to-neon-500">Inscription</h1>

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm, {'attr': {'class': 'space-y-4'}}) }}
      {{ form_row(registrationForm.username, {
        label: 'Nom d\'utilisateur',
        label_attr: {'class': 'block text-sm text-slate-300'},
        attr: {'class': 'mt-1 w-full rounded-md border border-slate-700 bg-night-900/60 text-slate-100 placeholder-slate-500 focus:border-neon-500 focus:ring-neon-500'}
      }) }}

      {{ form_row(registrationForm.plainPassword, {
        label: 'Mot de passe',
        label_attr: {'class': 'block text-sm text-slate-300'},
        attr: {'class': 'mt-1 w-full rounded-md border border-slate-700 bg-night-900/60 text-slate-100 placeholder-slate-500 focus:border-neon-500 focus:ring-neon-500'}
      }) }}

      {{ form_row(registrationForm.agreeTerms, {
        label_attr: {'class': 'text-sm text-slate-300'},
        attr: {'class': 'rounded accent-neon-500'}
      }) }}

      <button type="submit" class="w-full inline-flex justify-center items-center gap-2 px-4 py-2 rounded-md bg-gradient-to-r from-sakura-500 to-neon-500 text-night-900 font-semibold hover:opacity-90">Créer le compte</button>
    {{ form_end(registrationForm) }}
  </div>
</section>
{% endblock %}
