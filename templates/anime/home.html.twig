{% extends 'base.html.twig' %}
{% block title %}Manga Hub{% endblock %}
{% block body %}
<h1 class="text-3xl md:text-4xl font-display font-bold mb-6 text-transparent bg-clip-text bg-gradient-to-r from-sakura-500 to-neon-500">Top animes</h1>
<ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
  {% for a in top %}
    <li>
      <a href="{{ path('anime_show', {slug: a.slug}) }}" class="group block rounded-xl overflow-hidden border border-slate-800 bg-night-800/40 hover:bg-night-800/60 hover:border-neon-500 transition">
        <div class="relative aspect-[3/4] bg-slate-800">
          {% if a.coverUrl %}
            <img src="{{ a.coverUrl }}" alt="{{ a.title }}" class="absolute inset-0 w-full h-full object-cover">
          {% endif %}
          <div class="absolute inset-0 bg-gradient-to-t from-night-900/80 via-night-900/10 to-transparent opacity-70 group-hover:opacity-80 transition"></div>
          <div class="absolute bottom-0 left-0 right-0 p-3">
          </div>
        </div>
        <div class="p-3">
          <div class="flex items-center justify-between gap-2">
            <h3 class="text-sm md:text-base font-semibold text-slate-100 truncate">{{ a.title }}</h3>
            <span class="text-[11px] md:text-xs inline-flex items-center px-2 py-0.5 rounded-full bg-slate-800/70 border border-slate-700 text-slate-300">{{ a.avgRating ? '★ ' ~ a.avgRating : '—' }}</span>
          </div>
        </div>
      </a>
    </li>
  {% endfor %}
  {% if top is empty %}
    <li class="col-span-full text-slate-400">Aucun anime pour le moment.</li>
  {% endif %}
</ul>
<p class="mt-8">
  <a class="inline-flex items-center gap-2 text-slate-300 hover:text-white underline decoration-neon-500 underline-offset-4" href="{{ path('anime_index') }}">Voir tous les animes →</a>
  </p>
{% endblock %}
