{% extends 'base.html.twig' %}
{% block title %}Tous les animes{% endblock %}
{% block body %}
<h1 class="text-3xl md:text-4xl font-display font-bold mb-6 text-transparent bg-clip-text bg-gradient-to-r from-sakura-500 to-neon-500">Tous les animes</h1>
<ul class="divide-y divide-slate-800 rounded-xl border border-slate-800 bg-night-800/40 backdrop-blur">
  {% for a in animes %}
    <li class="group flex items-center justify-between p-3 hover:bg-night-800/60 transition">
      <a class="text-slate-200 hover:text-white underline decoration-neon-500 underline-offset-4" href="{{ path('anime_show', {slug: a.slug}) }}">{{ a.title }}</a>
      <span class="text-slate-500 group-hover:text-slate-300">→</span>
    </li>
  {% endfor %}
  {% if animes is empty %}
    <li class="p-3 text-slate-400">Aucun anime pour le moment.</li>
  {% endif %}
</ul>
{% endblock %}
